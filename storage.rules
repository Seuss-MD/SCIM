rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // AI enrichment temp uploads
    match /items/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Workspace image uploads used by sync
    match /workspaces/{workspaceId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == workspaceId;
    }
  }
}