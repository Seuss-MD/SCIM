rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return request.auth.uid;
    }

    function isPersonalWorkspace(workspaceId) {
      return signedIn() && workspaceId == me();
    }

    function isGroupMember(workspaceId) {
      return signedIn()
        && firestore.exists(
          /databases/(default)/documents/groups/$(workspaceId)/members/$(me())
        );
    }

    function isGroupOwner(workspaceId) {
      return isGroupMember(workspaceId)
        && firestore.get(
          /databases/(default)/documents/groups/$(workspaceId)/members/$(me())
        ).data.role == 'owner';
    }

    function canReadWorkspace(workspaceId) {
      return isPersonalWorkspace(workspaceId) || isGroupMember(workspaceId);
    }

    function canWriteWorkspace(workspaceId) {
      return isPersonalWorkspace(workspaceId) || isGroupMember(workspaceId);
    }

    function canDeleteWorkspaceFiles(workspaceId) {
      return isPersonalWorkspace(workspaceId) || isGroupOwner(workspaceId);
    }

    // AI enrichment temp uploads
    match /items/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Synced workspace images
    match /workspaces/{workspaceId}/{allPaths=**} {
      allow read: if canReadWorkspace(workspaceId);
      allow create, update: if canWriteWorkspace(workspaceId);
      allow delete: if canDeleteWorkspaceFiles(workspaceId);
    }
  }
}